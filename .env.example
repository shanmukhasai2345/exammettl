# Copy this file to .env and fill in your values
# Never commit .env to git!

MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/exam_system?retryWrites=true&w=majority
SECRET_KEY=change_this_to_a_random_secret_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Base URL of your site (used in reset email links)
# e.g. https://your-app.vercel.app  or  http://localhost:5000
BASE_URL=http://localhost:5000

# SMTP settings for sending password reset emails
# For Gmail: enable "App Passwords" in Google Account and use that as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM_NAME=Exammettl
SMTP_FROM_EMAIL=your_email@gmail.com
